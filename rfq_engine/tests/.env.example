# Copy this file to `.env` and fill in real values for local test runs.
# `.env` itself is gitignored; this file is the committed template.

# --- Local checkout layout ------------------------------------------------- #
# Absolute path to the silvaengine source root (used by conftest.py to extend sys.path)
base_dir=/absolute/path/to/silvaengine

# --- AWS credentials (DynamoDB access for integration tests) -------------- #
region_name=us-west-2
aws_access_key_id=<your-aws-access-key-id>
aws_secret_access_key=<your-aws-secret-access-key>

# --- Deployed GraphQL endpoint (only used by remote integration tests) ---- #
API_URL=https://<api-gateway-host>/<stage>/core/{endpoint_id}/ai_rfq_graphql
API_KEY=<your-api-key>

# --- Engine tenancy / partitioning ---------------------------------------- #
endpoint_id=<your-endpoint-id>
part_id=<your-part-id>
execute_mode=local_for_all          # local_for_all | local_for_sqs | local_for_aws_lambda
initialize_tables=0
cache_enabled=0

# --- Dual-backend selection ------------------------------------------------- #
# DB_BACKEND selects the active persistence backend at deployment time.
#   dynamodb  (default) — uses the AWS credentials above.
#   postgresql          — uses the PostgreSQL connection below; AWS credentials
#                         are optional (only needed for S3 File operations).
DB_BACKEND=dynamodb

# --- PostgreSQL connection (used when DB_BACKEND=postgresql) --------------- #
# Either DATABASE_URL or the PG_* keys below. When DATABASE_URL is set it wins.
# DATABASE_URL=postgresql+psycopg2://<user>:<password>@<host>:<port>/<db>
PG_HOST=localhost
PG_PORT=5432
PG_USER=silvaengine
PG_PASSWORD=silvaengine
PG_DB=silvaengine

# Table prefix for PostgreSQL — prepended to all table and index names
# to avoid collisions in shared databases (e.g. KGE uses "kge_").
PG_TABLE_PREFIX=rfq_

# KGE table prefix — used by prepare_flight_catalog_refs.py and the RFQ catalog
# handler to override pg_table_prefix when invoking knowledge_graph_engine via
# Invoker.invoke_funct_on_local. Mirrors the gateway's KGE_PG_TABLE_PREFIX.
KGE_PG_TABLE_PREFIX=kge_

# --- Knowledge Graph Engine (required for prepare_flight_catalog_refs.py) - #
# Only needed when running the ingestion path that calls KGE's executeExtract.
# Skipped when SEED_CATALOG_SKIP_INGEST=1 (link-only mode).
#
# LLM used for entity / relationship extraction:
llm_type=openai                                        # openai | anthropic | ollama | vertexai | mistralai
llm_name=gpt-4o                                        # model id appropriate to llm_type
openai_api_key=<your-openai-api-key>                   # required when llm_type=openai
# openai_base_url=<https://...>                        # optional override (Azure / proxy / local)
# anthropic_api_key=<your-anthropic-api-key>           # required when llm_type=anthropic
# ollama_host=http://localhost:11434                   # required when llm_type=ollama
# mistralai_api_key=<your-mistral-api-key>             # required when llm_type=mistralai
#
# Vector embeddings used for the KGE vector index:
embedding_provider=openai                              # defaults to llm_type when unset
embedding_model=text-embedding-3-small                 # dimensions auto-resolved for common OpenAI models
# embedding_dimensions=1536                            # override only for non-standard models
#
# Neo4j instance is NOT supplied here — register it once per partition_key via
# the insertUpdateNeo4jInstance mutation; KGE reads it from the kge-neo4j_instances
# DynamoDB table at runtime.

# --- Test selector (conftest.py uses this to filter pytest collection) ---- #
# AI_RFQ_TEST_FUNCTION=test_graphql_ping_py
# AI_RFQ_TEST_MARKERS=unit

